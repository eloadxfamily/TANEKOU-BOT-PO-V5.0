# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ── Pocket Option ─────────────────────────────────────────
PO_SSID=XXX-votre-ssid-ici
PO_DEMO=true

# ── Gestion des mises (Kelly fractional) ──────────────────
# Mise plancher ($ minimum par trade si solde inconnu ou trop faible)
BASE_AMOUNT=1.0
# Fraction du solde risquée par trade — recommandé : 0.01 (1%) à 0.02 (2%)
KELLY_FRACTION=0.01

# ── Filtres de qualité de signal ──────────────────────────
# Score minimum (0-100) pour qu'un signal soit tradé — recommandé : 82+
MIN_SIGNAL_SCORE=82
# Nombre minimum d'indicateurs alignés dans la même direction
MIN_CONFLUENCES=3

# ── Filtre de session (UTC) ───────────────────────────────
# true = trader uniquement London Open (08-10h) + NY Open (13-15h UTC)
# false = trader 24h/24 (non recommandé sur OTC)
SESSION_FILTER_ENABLED=true

# ── Risk management ───────────────────────────────────────
# Expiration des trades en secondes
TRADE_EXPIRATION=60
# Perte journalière maximum en % du solde de départ → arrêt automatique
MAX_DAILY_LOSS_PERCENT=10

# ── Paires actives ────────────────────────────────────────
ACTIVE_PAIRS=EURUSD_otc,AUDCAD_otc,GBPUSD_otc,USDJPY_otc
